# dependencies
node_modules/

# build output
dist/
.next/
.vercel/

# env files
.env
.env.*
!.env.example

# logs
*.log
reports/

# OS files
.DS_Store

# coverage
coverage/

# local persisted dev data (conversation store)
data/

# gold-corpus incremental harvest (customer-derived; NEVER auto-commit — promotion is approve-first)
data/gold_corpus/

# HD current-catalog (scraped nightly from harley-davidson.com; runtime data, not source)
data/hd_catalog/

# production/runtime state
services/api/data/scheduler_config.json
services/api/data/google_tokens.json
services/api/data/mdf_portal_runs/
services/api/data/automation_runs.json
services/api/data/campaigns.json
services/api/data/contact_lists.json
services/api/.env
data/conversations.json

# Local-only dealer deploy profiles (real host values); commit the .example template only
infra/deploy/*.api.env

# allow lead source catalogs to be committed
!services/api/data/
!services/api/data/lead_sources/
!services/api/data/lead_sources/*.json

sample.adf.xml
.vercel

# agent skills (installed locally via npx skills)
.agents/
.claude/skills/
skills-lock.json
