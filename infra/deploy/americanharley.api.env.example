# Copy to infra/deploy/americanharley.api.env locally and adjust if needed.
# Do not put secrets in this file. Secrets stay in the remote API .env file.

DEPLOY_HOST=ubuntu@api.leadrider.ai
DEPLOY_REPO_URL=https://github.com/jrich90b/throttleiq.git
DEPLOY_REPO=/home/ubuntu/leadrider-api/americanharley
DEPLOY_BRANCH=main

# American Harley currently runs as the first isolated dealer API.
DEPLOY_DATA_DIR=/home/ubuntu/leadrider-runtime/americanharley/data
DEPLOY_ENV_FILE=/home/ubuntu/leadrider-runtime/americanharley/api.env
# DEPLOY_ENV_FILE is the box-side runtime env (secrets + runtime feature flags). It is NOT in
# git, and the deploy VALIDATES it rather than overwriting it — so hand-set flags survive a normal
# `npm run deploy:api`. They are only lost if this runtime env is rebuilt from scratch. Canary
# runtime flags American Harley is expected to run (re-set these on a from-scratch rebuild):
#   TURN_UNDERSTANDING_MODEL_AUTHORITY=1   # over-attachment guard (model-resolution authority); live canary, watch answer_correctness owned_bike_offered
DEPLOY_PM2_PROCESS=throttleiq-api
DEPLOY_HEALTH_URL=https://api.americanharley.leadrider.ai/health
DEPLOY_REPLACE_PM2=1

# Production safety rails. These catch wrong-folder deploys and store-load
# regressions before the API can keep running against a tiny or wrong dataset.
DEPLOY_EXPECTED_DATA_DIR=/home/ubuntu/leadrider-runtime/americanharley/data
DEPLOY_MIN_CONVERSATIONS=400
DEPLOY_REQUIRED_CONVERSATION_TEXT="Michael Crosson"

# Keep this off for normal deploys. A dirty server means someone patched
# production manually and the drift should be reconciled first.
DEPLOY_ALLOW_DIRTY_REMOTE=0
