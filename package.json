{
  "name": "throttleiq",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @throttleiq/api run dev",
    "dev:worker": "npm --workspace @throttleiq/worker run dev",
    "dev": "concurrently -n api,worker -c auto \"npm:dev:api\" \"npm:dev:worker\"",
    "build": "npm -ws run build",
    "start:api": "npm --workspace @throttleiq/api run start",
    "start:worker": "npm --workspace @throttleiq/worker run start",
    "intent:eval": "LLM_ENABLED=1 LLM_INTENT_PARSER_ENABLED=1 npx tsx scripts/intent_parser_eval.ts",
    "intent:add": "npx tsx scripts/intent_parser_add.ts",
    "pricing_payments:eval": "LLM_ENABLED=1 LLM_PRICING_PAYMENTS_PARSER_ENABLED=1 npx tsx scripts/pricing_payments_intent_eval.ts",
    "accessory_request:eval": "LLM_ENABLED=1 LLM_ACCESSORY_REQUEST_PARSER_ENABLED=1 npx tsx scripts/accessory_request_eval.ts",
    "vehicle_fact:eval": "LLM_ENABLED=1 LLM_VEHICLE_FACT_PARSER_ENABLED=1 npx tsx scripts/vehicle_fact_question_eval.ts",
    "vehicle_info:eval": "LLM_ENABLED=1 LLM_VEHICLE_INFO_PARSER_ENABLED=1 npx tsx scripts/vehicle_info_request_eval.ts",
    "composite_sales_inquiry:eval": "LLM_ENABLED=1 LLM_COMPOSITE_SALES_INQUIRY_PARSER_ENABLED=1 npx tsx scripts/composite_sales_inquiry_eval.ts",
    "first_time_rider_guidance:eval": "LLM_ENABLED=1 LLM_FIRST_TIME_RIDER_GUIDANCE_PARSER_ENABLED=1 npx tsx scripts/first_time_rider_guidance_eval.ts",
    "faq_topic:eval": "LLM_ENABLED=1 LLM_FAQ_TOPIC_PARSER_ENABLED=1 npx tsx scripts/dealership_faq_topic_eval.ts",
    "inventory_entity:eval": "LLM_ENABLED=1 LLM_INVENTORY_ENTITY_PARSER_ENABLED=1 npx tsx scripts/inventory_entity_eval.ts",
    "inventory_status:eval": "LLM_ENABLED=1 LLM_INVENTORY_STATUS_PARSER_ENABLED=1 npx tsx scripts/inventory_status_eval.ts",
    "inventory_fact_answer:eval": "npx tsx scripts/inventory_fact_answer_eval.ts",
    "appointment_timing:eval": "LLM_ENABLED=1 LLM_APPOINTMENT_TIMING_PARSER_ENABLED=1 node -r dotenv/config ./node_modules/.bin/tsx scripts/appointment_timing_eval.ts",
    "customer_ack_action:eval": "LLM_ENABLED=1 LLM_CUSTOMER_ACK_ACTION_PARSER_ENABLED=1 npx tsx scripts/customer_ack_action_eval.ts",
    "manual_outbound_appointment:eval": "LLM_ENABLED=1 LLM_MANUAL_OUTBOUND_APPOINTMENT_PARSER_ENABLED=1 npx tsx scripts/manual_outbound_appointment_eval.ts",
    "cadence_regenerate_context:eval": "LLM_ENABLED=1 LLM_CADENCE_REGENERATE_CONTEXT_PARSER_ENABLED=1 npx tsx scripts/cadence_regenerate_context_eval.ts",
    "conversation_state:eval": "LLM_ENABLED=1 LLM_CONVERSATION_STATE_PARSER_ENABLED=1 npx tsx scripts/conversation_state_eval.ts",
    "parts_catalog_lexicon:eval": "npx tsx scripts/parts_catalog_lexicon_eval.ts",
    "trade_payoff:eval": "LLM_ENABLED=1 LLM_TRADE_PAYOFF_PARSER_ENABLED=1 npx tsx scripts/trade_payoff_eval.ts",
    "watch_catalog_eval": "LLM_ENABLED=1 npx tsx scripts/watch_catalog_eval.ts",
    "finance_docs_eval": "LLM_ENABLED=1 npx tsx scripts/finance_docs_eval.ts",
    "adf_policy:eval": "npx tsx scripts/adf_policy_eval.ts",
    "disposition_transition:eval": "npx tsx scripts/disposition_transition_eval.ts",
    "response_control:eval": "npx tsx scripts/response_control_eval.ts",
    "purchase_delivery_logistics:eval": "LLM_ENABLED=1 LLM_PURCHASE_DELIVERY_LOGISTICS_PARSER_ENABLED=1 npx tsx scripts/purchase_delivery_logistics_eval.ts",
    "regenerate_selection:eval": "npx tsx scripts/regenerate_selection_eval.ts",
    "conversation_replay:eval": "npx tsx scripts/conversation_replay_eval.ts",
    "inbound_shadow:replay": "npx tsx scripts/inbound_shadow_replay.ts",
    "route_watchdog:run": "npx tsx scripts/route_audit_watchdog.ts",
    "inbound_pipeline:eval": "npx tsx scripts/inbound_pipeline_eval.ts",
    "reply_path:audit": "npx tsx scripts/customer_reply_path_audit.ts",
    "language_corpus:mine": "npx tsx scripts/language_corpus_mine.ts",
    "voice_feedback:mine": "npx tsx scripts/voice_feedback_mine.ts",
    "deterministic_rules:promote": "npx tsx scripts/deterministic_rules_promote.ts",
    "manual_outbound:promote": "npx tsx scripts/manual_outbound_promote.ts",
    "agent_manager:report": "npx tsx scripts/agent_manager_report.ts",
    "language_seed:eval": "npx tsx scripts/language_seed_fixture_eval.ts",
    "multi_turn:eval": "npx tsx scripts/multi_turn_synthetic_eval.ts",
    "orchestrator_regression:eval": "npx tsx scripts/orchestrator_regression_eval.ts",
    "route_state:eval": "npx tsx scripts/route_state_reducer_eval.ts",
    "workflow_regression:eval": "npx tsx scripts/workflow_regression_eval.ts",
    "chat_simulation:sweep": "npx tsx scripts/chat_simulation_sweep.ts",
    "finance_language_fuzz:eval": "npx tsx scripts/finance_language_fuzz_eval.ts",
    "tone_quality:eval": "npx tsx scripts/tone_quality_eval.ts",
    "tone_quality:fixture_eval": "npx tsx scripts/tone_quality_fixture_eval.ts",
    "web_text_widget:eval": "npx tsx scripts/web_text_widget_eval.ts",
    "post_sale_cadence:backfill": "npx tsx scripts/backfill_post_sale_cadence.ts",
    "walkin_outcome:eval": "LLM_ENABLED=1 LLM_WALKIN_OUTCOME_PARSER_ENABLED=1 npx tsx scripts/walkin_outcome_eval.ts",
    "conversation:audit": "npx tsx scripts/conversation_audit.ts",
    "export:changed_messages": "npx tsx scripts/export_changed_messages.ts",
    "edit_feedback:mine": "npx tsx scripts/edit_feedback_mine.ts",
    "edit_feedback:email": "npx tsx scripts/send_feedback_report_email.ts",
    "automation_run:record": "npx tsx scripts/record_automation_run.ts",
    "support_mail:poll": "npx tsx scripts/support_mail_poll.ts",
    "mdf:portal": "npx tsx scripts/mdf_portal_runner.ts",
    "mdf:portal:daemon": "npx tsx scripts/mdf_portal_runner_daemon.ts",
    "tlp_debug:email": "npx tsx scripts/send_tlp_debug_email.ts",
    "deploy:api": "bash scripts/deploy_api_lightsail.sh",
    "edit_feedback:loop": "npm run conversation:audit && npm run edit_feedback:mine",
    "feedback:nightly": "bash scripts/feedback_loop_nightly.sh",
    "feedback:hourly": "bash scripts/feedback_loop_hourly.sh",
    "ci:eval": "npm run reply_path:audit && npm run adf_policy:eval && npm run response_control:eval && npm run disposition_transition:eval && npm run regenerate_selection:eval && npm run conversation_replay:eval && npm run route_state:eval && npm run inventory_fact_answer:eval && npm run inbound_pipeline:eval && npm run workflow_regression:eval && npm run orchestrator_regression:eval && npm run finance_language_fuzz:eval && npm run tone_quality:fixture_eval"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "geist": "^1.7.0",
    "libphonenumber-js": "^1.12.38"
  }
}
