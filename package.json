{
  "name": "throttleiq",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @throttleiq/api run dev",
    "dev:worker": "npm --workspace @throttleiq/worker run dev",
    "dev": "concurrently -n api,worker -c auto \"npm:dev:api\" \"npm:dev:worker\"",
    "build": "npm -ws run build",
    "start:api": "npm --workspace @throttleiq/api run start",
    "start:worker": "npm --workspace @throttleiq/worker run start",
    "intent:eval": "LLM_ENABLED=1 LLM_INTENT_PARSER_ENABLED=1 npx tsx scripts/intent_parser_eval.ts",
    "intent:add": "npx tsx scripts/intent_parser_add.ts",
    "pricing_payments:eval": "LLM_ENABLED=1 LLM_PRICING_PAYMENTS_PARSER_ENABLED=1 npx tsx scripts/pricing_payments_intent_eval.ts",
    "trade_payoff:eval": "LLM_ENABLED=1 LLM_TRADE_PAYOFF_PARSER_ENABLED=1 npx tsx scripts/trade_payoff_eval.ts",
    "watch_catalog_eval": "LLM_ENABLED=1 npx tsx scripts/watch_catalog_eval.ts",
    "finance_docs_eval": "LLM_ENABLED=1 npx tsx scripts/finance_docs_eval.ts",
    "adf_policy:eval": "npx tsx scripts/adf_policy_eval.ts",
    "disposition_transition:eval": "npx tsx scripts/disposition_transition_eval.ts",
    "response_control:eval": "npx tsx scripts/response_control_eval.ts",
    "regenerate_selection:eval": "npx tsx scripts/regenerate_selection_eval.ts",
    "conversation_replay:eval": "npx tsx scripts/conversation_replay_eval.ts",
    "route_watchdog:run": "npx tsx scripts/route_audit_watchdog.ts",
    "language_corpus:mine": "npx tsx scripts/language_corpus_mine.ts",
    "deterministic_rules:promote": "npx tsx scripts/deterministic_rules_promote.ts",
    "manual_outbound:promote": "npx tsx scripts/manual_outbound_promote.ts",
    "language_seed:eval": "npx tsx scripts/language_seed_fixture_eval.ts",
    "multi_turn:eval": "npx tsx scripts/multi_turn_synthetic_eval.ts",
    "route_state:eval": "npx tsx scripts/route_state_reducer_eval.ts",
    "finance_language_fuzz:eval": "npx tsx scripts/finance_language_fuzz_eval.ts",
    "tone_quality:eval": "npx tsx scripts/tone_quality_eval.ts",
    "tone_quality:fixture_eval": "npx tsx scripts/tone_quality_fixture_eval.ts",
    "walkin_outcome:eval": "LLM_ENABLED=1 LLM_WALKIN_OUTCOME_PARSER_ENABLED=1 npx tsx scripts/walkin_outcome_eval.ts",
    "conversation:audit": "npx tsx scripts/conversation_audit.ts",
    "export:changed_messages": "npx tsx scripts/export_changed_messages.ts",
    "edit_feedback:mine": "npx tsx scripts/edit_feedback_mine.ts",
    "edit_feedback:email": "npx tsx scripts/send_feedback_report_email.ts",
    "edit_feedback:loop": "npm run conversation:audit && npm run edit_feedback:mine",
    "feedback:nightly": "bash scripts/feedback_loop_nightly.sh",
    "ci:eval": "npm run adf_policy:eval && npm run response_control:eval && npm run disposition_transition:eval && npm run regenerate_selection:eval && npm run conversation_replay:eval && npm run route_state:eval && npm run finance_language_fuzz:eval && npm run tone_quality:fixture_eval"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "geist": "^1.7.0",
    "libphonenumber-js": "^1.12.38"
  }
}
