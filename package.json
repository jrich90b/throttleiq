{
  "name": "throttleiq",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @throttleiq/api run dev",
    "dev:worker": "npm --workspace @throttleiq/worker run dev",
    "dev": "concurrently -n api,worker -c auto \"npm:dev:api\" \"npm:dev:worker\"",
    "build": "npm -ws run build",
    "start:api": "npm --workspace @throttleiq/api run start",
    "start:worker": "npm --workspace @throttleiq/worker run start",
    "intent:eval": "LLM_ENABLED=1 LLM_INTENT_PARSER_ENABLED=1 npx tsx scripts/intent_parser_eval.ts",
    "intent:add": "npx tsx scripts/intent_parser_add.ts",
    "trade_payoff:eval": "LLM_ENABLED=1 LLM_TRADE_PAYOFF_PARSER_ENABLED=1 npx tsx scripts/trade_payoff_eval.ts",
    "watch_catalog_eval": "LLM_ENABLED=1 npx tsx scripts/watch_catalog_eval.ts",
    "finance_docs_eval": "LLM_ENABLED=1 npx tsx scripts/finance_docs_eval.ts",
    "adf_policy:eval": "npx tsx scripts/adf_policy_eval.ts",
    "disposition_transition:eval": "npx tsx scripts/disposition_transition_eval.ts",
    "response_control:eval": "npx tsx scripts/response_control_eval.ts",
    "regenerate_selection:eval": "npx tsx scripts/regenerate_selection_eval.ts",
    "conversation_replay:eval": "npx tsx scripts/conversation_replay_eval.ts"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "geist": "^1.7.0",
    "libphonenumber-js": "^1.12.38"
  }
}
